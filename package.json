{
  "name": "polislike-partykit-reaction-canvas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build:worker": "esbuild app/workers/embeddingWorker.ts --bundle --format=esm --platform=browser --outfile=public/embeddingWorker.js && esbuild app/workers/druidWorker.ts --bundle --format=esm --platform=browser --outfile=public/druidWorker.js",
    "build:worker-watch": "concurrently 'esbuild app/workers/embeddingWorker.ts --bundle --format=esm --platform=browser --outfile=public/embeddingWorker.js --watch=forever' 'esbuild app/workers/druidWorker.ts --bundle --format=esm --platform=browser --outfile=public/druidWorker.js --watch=forever'",
    "dev": "pnpm run cachebust && concurrently --kill-others 'pnpm run build:worker-watch' 'partykit dev --live'",
    "dev-https": "pnpm run cachebust && concurrently --kill-others 'pnpm run build:worker-watch' 'partykit dev --live --https'",
    "deploy": "pnpm run build:worker && pnpm run cachebust && partykit deploy",
    "deploy:preview": "pnpm run build:worker && pnpm run cachebust && partykit deploy --preview $PREVIEW_NAME",
    "deploy:staging": "PREVIEW_NAME=staging pnpm run deploy:preview",
    "deploy:perf": "PREVIEW_NAME=perf pnpm run deploy:preview",
    "cachebust": "node scripts/build-with-cachebust.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "pnpm dlx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "perf": "echo 'Observe at: http://localhost:1999/#perf' && k6 run perf/load-test-k6.js",
    "perf-100": "pnpm run perf --vus 100 --duration 30s",
    "perf:remote": "echo 'Observe at: https://perf.whispering-gallery.patcon.partykit.dev/#perf' && k6 run --env WS_URL=wss://perf.whispering-gallery.patcon.partykit.dev/parties/perf/default perf/load-test-k6.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@saehrimnir/druidjs": "github:patcon/DruidJS#add-pacmap-support",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-router": "^1.170.15",
    "@types/d3": "^7.4.3",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "d3": "^7.9.0",
    "ghost-cursor": "^1.4.1",
    "partysocket": "^1.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "reddwarf-ts": "github:patcon/polislike-human-cartography-prototype-v2#803d564&path:packages/reddwarf-ts",
    "simplex-noise": "^4.0.3",
    "three": "^0.183.2",
    "umap-js": "^1.4.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.1.0",
    "@storybook/addon-docs": "^10.1.0",
    "@storybook/addon-vitest": "^10.1.0",
    "@storybook/react-vite": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.183.1",
    "@vitest/browser-playwright": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "partykit": "^0.0.110",
    "playwright": "^1.61.1",
    "storybook": "^10.1.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.14"
  }
}
