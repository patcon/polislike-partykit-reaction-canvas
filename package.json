{
  "name": "polislike-partykit-reaction-canvas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build:worker": "esbuild app/workers/embeddingWorker.ts --bundle --format=esm --platform=browser --outfile=public/embeddingWorker.js",
    "build:worker-watch": "esbuild app/workers/embeddingWorker.ts --bundle --format=esm --platform=browser --outfile=public/embeddingWorker.js --watch=forever",
    "dev": "trap 'pkill -f embeddingWorker 2>/dev/null' EXIT INT TERM; pnpm run build:worker-watch & partykit dev --live",
    "dev-https": "trap 'pkill -f embeddingWorker 2>/dev/null' EXIT INT TERM; pnpm run build:worker-watch & partykit dev --live --https",
    "deploy": "pnpm run build:worker && pnpm run cachebust && partykit deploy",
    "deploy:staging": "pnpm run build:worker && pnpm run cachebust && partykit deploy --preview staging",
    "cachebust": "node scripts/build-with-cachebust.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/d3": "^7.4.3",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "d3": "^7.9.0",
    "ghost-cursor": "^1.4.1",
    "partysocket": "^1.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.183.2",
    "umap-js": "^1.4.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.1.0",
    "@storybook/addon-docs": "^10.1.0",
    "@storybook/addon-vitest": "^10.1.0",
    "@storybook/react-vite": "^10.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.183.1",
    "@vitest/browser-playwright": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "esbuild": "^0.28.0",
    "partykit": "^0.0.110",
    "playwright": "^1.57.0",
    "storybook": "^10.1.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.14"
  }
}
